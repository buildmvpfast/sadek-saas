# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.com

# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MetaAPI
METAAPI_TOKEN=your_metaapi_token
METAAPI_PROVISIONING_REGION=london
METAAPI_ACCOUNT_TYPE=cloud-g2
# MT4 (FXcess) — cloud-g1 recommandé
METAAPI_ACCOUNT_TYPE_MT4=cloud-g1
METAAPI_CONNECT_MAX_WAIT_MS=110000

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# OpenAI (for signal parsing)
OPENAI_API_KEY=sk-...

# Security — GENERATE WITH: openssl rand -hex 32
# Used to authenticate internal server-to-server API calls (cron, webhooks)
INTERNAL_API_SECRET=generate_with_openssl_rand_hex_32

# Telegram webhook secret — set this in BotFather when registering webhook
# Must match X-Telegram-Bot-Api-Secret-Token header sent by Telegram
# Register with: node scripts/setup-telegram-webhook-full.js
TELEGRAM_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# App URL (required for Stripe webhook to close positions on subscription cancel)
NEXT_PUBLIC_APP_URL=https://your-app.netlify.app

# Backend Express service secret (reuses INTERNAL_API_SECRET if not set separately)
BACKEND_API_SECRET=generate_with_openssl_rand_hex_32

# Render workers (optionnel)
NODE_VERSION=20

# Backend Express (backend/ — optionnel)
PORT=4000
AUTO_START=false
NODE_ENV=development

# Upstash Redis (optionnel — rate limit prod)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
